<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <Button
        android:id="@+id/button_dodaj_zaang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="rozdysponuj premie" />

    <Button
        android:id="@+id/button_dodaj_obecnosc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="uzupełnij obecności" />

    <Button
        android:id="@+id/button_wydaj_wynagrodzenia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="wydaj wynagrodzenia" />

    <Button
        android:id="@+id/button_szczegoly_wynagrodzen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="szczegóły" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="invisible" />

</LinearLayout>